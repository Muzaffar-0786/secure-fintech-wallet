# ==========================
# APP CONFIG
# ==========================
APP_NAME=Secure FinTech Wallet API
APP_VERSION=1.0.0
DEBUG=True

# ==========================
# DATABASE
# ==========================
DATABASE_URL=postgresql://postgres:password@localhost:5432/fintech_wallet

# ==========================
# JWT
# ==========================
SECRET_KEY=change_this_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================
# WALLET
# ==========================
WELCOME_BONUS=100
DAILY_REWARD=20

# ==========================
# CORS
# ==========================
ALLOWED_ORIGINS=*

# ==========================
# ADMIN
# ==========================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
